# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200

# MySQL (matches docker-compose.yml)
DB_HOST=localhost
DB_PORT=3306
DB_USER=appuser
DB_PASS=secret
DB_NAME=techx_tasks

# MongoDB (matches docker-compose.yml; used in Phase 3, scaffolded in Phase 1)
MONGO_URI=mongodb://localhost:27017/techx_tasks

# JWT (Phase 3 — placeholder so config.ts shape stays stable)
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=24h
